generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Animal {
  id                String   @id @default(uuid())
  qr_code           String   @unique
  species           String
  name              String?
  birth_date        DateTime? @db.Date
  parent_father     String?
  parent_mother     String?
  medications       Json     @default("[]")
  pregnancies       Json     @default("[]")
  lactation_periods Json     @default("[]")
  offspring         Json     @default("[]")
  weight_records    Json     @default("[]")
  created_at        DateTime @default(now()) @db.Timestamp(0)

  @@map("animals")
}